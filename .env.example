# Environment Configuration Template

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
API_WORKERS=4

# Database Configuration
DATABASE_URL=postgresql://farmer:password@localhost:5432/plant_disease_db

# LLM Configuration
LLM_MODEL=llama2
LLM_API_URL=http://localhost:11434/api
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
LLM_USE_LOCAL=true

# Vector Database (Chroma - Local)
CHROMA_PERSIST_DIR=./data/vector_store

# Multilingual Configuration
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,hi,ta,te,ka,ml,kn,mr,gu,bn
TRANSLATION_SERVICE=indicnlp
TTS_ENGINE=indic_tts

# Model Configuration
VISION_MODEL=efficientnet_v2
VISION_MODEL_PATH=./models/vision/
CONFIDENCE_THRESHOLD=0.6

# MLOps Configuration (Local)
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ARTIFACT_STORE=./mlruns
ENABLE_DRIFT_MONITORING=true

# Image Processing
MAX_IMAGE_SIZE=10485760
ALLOWED_IMAGE_FORMATS=jpg,jpeg,png,webp
IMAGE_UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/app.log

# Security
SECRET_KEY=your-secret-key-here
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Feature Flags
ENABLE_FEEDBACK_LOOP=true
ENABLE_OFFLINE_MODE=false
